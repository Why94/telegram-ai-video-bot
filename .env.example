# Environment Variables Template
# Copy this file to .env and fill in your values

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=8895500720:AAHaN5xZLBeNjEZs17MJ22rpflYVBXRjyy4

# Provider API Keys (Set at least one of these to use the corresponding provider)
BYTEPLUS_API_KEY=ark-3ffdbe9e-d77a-41c8-b47d-6ff52c3ee8b4-c0399
KLING_API_KEY=your_kling_api_key_here
MINIMAX_API_KEY=your_minimax_hailuo_api_key_here
LUMA_API_KEY=your_luma_api_key_here
RUNWAY_API_KEY=your_runway_api_key_here
GOOGLE_VEO_KEY=your_google_cloud_credentials_here
LEONARDO_API_KEY=your_leonardo_api_key_here
REPLICATE_API_KEY=your_replicate_api_key_here
RUNNINGHUB_API_KEY=your_runninghub_api_key_here
FREETHEAI_API_KEY=your_freetheai_api_key_here

# KIE.ai API Key (80 free credits for new users, no credit card needed)
# Sign up at https://kie.ai → get key at https://kie.ai/api-key
KIE_API_KEY=your_kie_api_key_here

# Optional: Default active provider (byteplus, kling, hailuo, luma, runway, veo, replicate, runninghub, freetheai, kie)
DEFAULT_PROVIDER=byteplus

# Optional: Default video settings
DEFAULT_RESOLUTION=720p
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_DURATION=auto
GENERATE_AUDIO=true

# ─── Admin Panel (Bulk Account Inventory) ────────────────────────────────────
# Comma-separated Telegram user IDs allowed to manage inventory (SUPER_ADMIN/ADMIN)
ADMIN_USER_IDS=123456789
# Secret key for encrypting account passwords at rest (use a long random string)
INVENTORY_ENCRYPTION_KEY=change_me_to_a_long_random_secret_key
# Path to the SQLite database file (optional, defaults to ./data/inventory.db)
INVENTORY_DB_PATH=./data/inventory.db
# Low stock warning threshold per product (optional, default 10)
INVENTORY_LOW_STOCK=10
